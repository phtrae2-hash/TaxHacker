# Variáveis para a Stack no Portainer
# Em Portainer: Stack > Add stack > Web editor > Environment variables
# Cole os nomes à esquerda e os valores à direita (sem aspas nos valores)

# Obrigatório - altere para uma senha forte
POSTGRES_PASSWORD=SuaSenhaSeguraPostgres123!

# Obrigatório - gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Opcional - para análise de faturas com IA
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=
